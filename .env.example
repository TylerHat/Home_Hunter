# Copy to `.env` and fill in. `.env` is git-ignored.

# Database connection.
# Local default (no setup): leave unset -> uses a local SQLite file (home_hunter.db).
# Production (free): a Neon Postgres URL, e.g.
#   postgresql+psycopg://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Path to the scrape config file (optional; defaults to ./config.yaml).
HOME_HUNTER_CONFIG=config.yaml
